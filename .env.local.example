# Skopiuj do .env.local i uzupełnij wartości.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcjonalnie — nieużywane przy dynamicznym price_data (rabaty wolumenowe w checkout).
# STRIPE_PRICE_ID=

RESEND_API_KEY=

NEXT_PUBLIC_APP_URL=https://najembezkary.pl

# Zalecane w produkcji — chroni POST /api/generate-docs (Bearer token).
INTERNAL_API_SECRET=

# Eksport raportu zgód (GET /api/export-consents) — min. 32 znaki, np. openssl rand -hex 32
EXPORT_API_SECRET=

# Logowanie do panelu /admin (HTTP Basic Auth)
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=

# Tylko lokalnie (npm run dev): pomiń Stripe i od razu generuj ZIP — przycisk na /platnosc
# Nigdy w produkcji.
DEV_SKIP_STRIPE=1
NEXT_PUBLIC_DEV_SKIP_STRIPE=1

# Opcjonalnie: przycisk „Dev: pomiń formularz → podsumowanie” na /dane (poza npm run dev).
# W dev przycisk jest widoczny bez tej zmiennej.
# NEXT_PUBLIC_DEV_SKIP_FORM=1

# KSeF (sesja tokenem API — src/lib/ksef-client.ts). Test: https://ksef-test.mf.gov.pl/api
# KSEF_API_BASE_URL=https://ksef-test.mf.gov.pl/api
# KSEF_API_TOKEN=
# KSEF_CONTEXT_NIP=
# Opcjonalnie — jeśli host KSEF_API_BASE_URL jest nietypowy:
# KSEF_PUBLIC_KEY_CERTIFICATES_URL=https://api-test.ksef.mf.gov.pl/api/v2/security/public-key-certificates
